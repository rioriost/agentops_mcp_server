#!/usr/bin/env bash
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "==> verify-release: start"

if ! command -v python >/dev/null 2>&1; then
  echo "ERROR: python not installed"
  exit 1
fi

if ! python -m pytest --version >/dev/null 2>&1; then
  echo "ERROR: pytest not installed"
  exit 1
fi

if ! python - <<'PY' >/dev/null 2>&1
import importlib.util
raise SystemExit(0 if importlib.util.find_spec("pytest_cov") else 1)
PY
then
  echo "ERROR: pytest-cov not installed"
  exit 1
fi

python -m pytest --cov=agentops_mcp_server --cov-report=term-missing --cov-report=xml

echo "==> verify-release: OK"
